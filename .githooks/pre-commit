#!/usr/bin/env bash
#
# pre-commit hook for inire/claude-skills
#
# Ensures the root README.md stays in sync with skills/*/SKILL.md changes.
# If you touch a SKILL.md without touching the root README, the commit is
# blocked — because the README is the index and it drifts silently otherwise.
#
# To bypass for a genuine typo-only change:
#   git commit --no-verify
#
# Install once per clone:
#   git config core.hooksPath .githooks

set -e

staged=$(git diff --cached --name-only --diff-filter=ACMR)

# Any SKILL.md under skills/*/ in the staged set?
skill_changed=$(echo "$staged" | grep -E '^skills/[^/]+/SKILL\.md$' || true)

if [ -z "$skill_changed" ]; then
  exit 0
fi

# Root README staged alongside?
readme_changed=$(echo "$staged" | grep -E '^README\.md$' || true)

if [ -n "$readme_changed" ]; then
  exit 0
fi

# Block.
echo "────────────────────────────────────────────────────────────────"
echo " pre-commit: SKILL.md changed without root README.md update"
echo "────────────────────────────────────────────────────────────────"
echo ""
echo " Changed skill files:"
echo "$skill_changed" | sed 's/^/   • /'
echo ""
echo " The root README.md is the index for all skills in this repo."
echo " When a SKILL.md changes, the README should reflect it — otherwise"
echo " the description, dimension count, trigger list, etc. drift out of"
echo " sync with what the skill actually does."
echo ""
echo " Fix:"
echo "   1. Update README.md to match the SKILL.md changes"
echo "   2. git add README.md"
echo "   3. git commit again"
echo ""
echo " Bypass (use sparingly — only for typo/whitespace/comment changes"
echo " that don't affect skill behavior):"
echo "   git commit --no-verify"
echo ""
exit 1
